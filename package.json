{
  "name": "lofersil-landing-page",
  "version": "1.0.0",
  "description": "LOFERSIL Landing Page - Static TypeScript site for Vercel deployment",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "npm run build:clean && npm run build:ts && npm run build:css && npm run build:static && npm run build:assets && echo '✅ Build completed successfully'",
    "build:prod": "NODE_ENV=production npm run build:clean && npm run build:ts:prod && npm run build:css && npm run build:static && npm run build:assets && echo '✅ Production build completed successfully'",
    "build:clean": "rm -rf dist && mkdir -p dist",
    "build:ts": "./node_modules/.bin/tsc",
    "build:ts:prod": "./node_modules/.bin/tsc --project tsconfig.prod.json",
    "build:ts:api": "tsc --project tsconfig.api.json",
    "build:css": "postcss src/styles/main.css -o dist/main.css",
    "build:static": "cp index.html privacy.html terms.html site.webmanifest robots.txt sitemap.xml dompurify.min.js favicon.svg dist/ 2>/dev/null || true && cp -r api dist/ 2>/dev/null || true",
    "build:assets": "cp -r assets dist/ 2>/dev/null || true",
    "build:dev": "npm run build",
    "dev": "tsc --watch",
    "start": "serve dist --single -l 3000",
    "serve-8000": "npm run build && cd dist && python -m http.server 8000",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.{ts,css}",
    "optimize-images": "imagemin assets/images/* --out-dir=dist/images",
    "prebuild": "npm run format",
    "lighthouse": "lighthouse http://localhost:3000 --output=html --output-path=./lighthouse-report.html",
    "health-check": "node tools/monitoring/deployment-health-check.js",
    "monitor": "node tools/monitoring/production-monitor.js",
    "monitor:start": "node tools/monitoring/production-monitor.js monitor",
    "monitor:performance": "node tools/monitoring/production-monitor.js performance",
    "monitor:report": "node tools/monitoring/production-monitor.js report",
    "vercel-deploy": "node scripts/deploy/deploy-to-vercel.js",
    "deploy:preview": "vercel",
    "deploy:prod": "vercel --prod",
    "build-and-serve-8000": "npm run build && serve dist --single -l 8000",
    "test:context7-docs": "tsx .opencode/tool/mcp/test-context7-docs.ts"
  },
  "keywords": [
    "landing-page",
    "typescript",
    "static-site",
    "vercel",
    "lofersil"
  ],
  "author": "LOFERSIL",
  "license": "MIT",
  "devDependencies": {
    "@axe-core/cli": "^4.11.0",
    "@eslint/js": "^9.0.0",
    "@types/dompurify": "^3.2.0",
    "@types/express": "^5.0.5",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^7.0.4",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "autoprefixer": "^10.4.0",
    "cssnano": "^6.0.0",
    "eslint": "^9.0.0",
    "favicons": "^7.2.0",
    "globals": "^15.0.0",
    "imagemin-cli": "^8.0.0",
    "jsdom": "^25.0.0",
    "lighthouse": "^13.0.1",
    "postcss": "^8.4.0",
    "postcss-cli": "^10.0.0",
    "prettier": "^3.0.0",
    "serve": "^14.2.0",
    "supertest": "^7.1.4",
    "terser": "^5.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": "20.x"
  },
  "packageManager": "npm@10.0.0",
  "dependencies": {
    "@opencode-ai/plugin": "^1.0.72",
    "cors": "^2.8.5",
    "dompurify": "^3.3.0",
    "dotenv": "^17.2.3",
    "express": "^5.0.0",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "joi": "^17.9.0",
    "nodemailer": "^7.0.10",
    "openai": "^6.0.0",
    "sharp": "^0.33.0",
    "web-vitals": "^5.1.0"
  }
}
